# ==========================================================
# NDIOBEEN GUI LOGISTIQUE — configuration e-mail (copier vers .env)
# Sans ces variables, le serveur passe en mode DÉMO (Ethereal) :
# les e-mails sont consultables via une URL de prévisualisation.
# ==========================================================

# --- Port du serveur web ---
PORT=8765

# --- Boîte qui reçoit les notifications internes ---
ADMIN_EMAIL=conciergerie@votre-domaine.sn

# --- Expéditeur affiché ---
MAIL_FROM="NDIOBEEN GUI LOGISTIQUE" <no-reply@votre-domaine.sn>

# --- Relais SMTP : décommentez UN bloc et remplissez ---

# SendGrid  (https://sendgrid.com — clé API)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# Resend  (https://resend.com — clé API)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Mailgun  (https://mailgun.com)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@mg.votre-domaine.sn
# SMTP_PASS=xxxxxxxxxxxxxxxxxxxxxxxx

# Amazon SES  (https://aws.amazon.com/ses)
# SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIAxxxxxxxxxxxxxxxx
# SMTP_PASS=xxxxxxxxxxxxxxxxxxxxxxxx

# Gmail  (mot de passe d'application : https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-adresse@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
